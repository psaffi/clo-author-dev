@article{duan_hu_mclean:2010,
	Abstract = {Previous studies have shown that high short interest stocks have low subsequent returns. We test whether the persistence of this effect is due to costs limiting arbitrage. The arbitrage cost that we focus on is idiosyncratic risk which, regardless of the arbitrageur's level of diversification, deters arbitrage activity. Consistent with costly arbitrage, we find that among high short interest stocks a one standard deviation increase in idiosyncratic risk predicts a more than 1\% decline in monthly returns. Moreover, idiosyncratic risk does not predict returns across low short interest stocks, and short interest does not predict low returns across low idiosyncratic risk stocks. Our results are robust to commonly used proxies for both transaction costs and short sale constraints.},
	Author = {Duan, Ying and Hu, Gang and McLean, R. David},
	Journal = {Journal of Financial Intermediation},
	Month = {October},
	Number = {4},
	Pages = {564-579},
	Title = {Costly arbitrage and idiosyncratic risk: Evidence from short sellers},
	Url = {http://ideas.repec.org/a/eee/jfinin/v19y2010i4p564-579.html},
	Volume = {19},
	Year = 2010,
	Bdsk-Url-1 = {http://ideas.repec.org/a/eee/jfinin/v19y2010i4p564-579.html}}


